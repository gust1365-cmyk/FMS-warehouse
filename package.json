{
  "name": "fms-warehouse",
  "version": "1.0.0",
  "description": "FMS 창고 로케이션 현황 대시보드",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64"
  },
  "author": "FMS",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.fms.warehouse",
    "productName": "FMS 창고 로케이션 현황",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FMS 창고 현황",
      "language": "1042"
    },
    "portable": {
      "artifactName": "FMS-창고현황-portable.exe"
    }
  }
}
